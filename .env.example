# ─── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (Database + Auth) ─────────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma connection strings (Supabase → Project Settings → Database)
# Use the pooled connection (port 6543, pgbouncer) for DATABASE_URL
# and the direct connection (port 5432) for DIRECT_URL.
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# ─── OpenRouter ─────────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Any OpenRouter model slug; falls back automatically if unavailable
OPENROUTER_MODEL=anthropic/claude-opus-4.8

# ─── Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price ID of the Pro plan ($12/month recurring)
STRIPE_PRO_PRICE_ID=price_...
